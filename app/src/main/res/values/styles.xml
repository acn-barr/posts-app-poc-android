<resources>

    <style name="BottomNavigationViewTextStyle">
        <item name="itemTextAppearanceInactive">@style/BottomNavigationTextInactive</item>
        <item name="itemTextAppearanceActive">@style/BottomNavigationTextActive</item>
        <item name="itemActiveIndicatorStyle">@style/CustomActiveIndicatorStyle</item>
        <item name="itemIconSize">28dp</item>
    </style>

    <style name="BottomNavigationTextInactive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black_90</item>
    </style>

    <style name="BottomNavigationTextActive" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="CustomActiveIndicatorStyle" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/bottom_nav_item_icon_background</item>
    </style>

</resources>
